# Domain base
DOMAIN=aivanguardlabs.com

# Email para certificados SSL (Let's Encrypt)
ACME_EMAIL=admin@aivanguardlabs.com

# Auth para dashboard de Traefik (generar con: htpasswd -nb admin tupassword)
# TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xyz$$hashedpassword
